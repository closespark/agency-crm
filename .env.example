# ============================================
# DATABASE (Railway PostgreSQL)
# ============================================
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ============================================
# REDIS (Railway Redis/Valkey)
# ============================================
REDIS_URL="redis://default:password@host:6379"

# ============================================
# AUTH
# ============================================
NEXTAUTH_SECRET="generate-a-secure-random-string"
NEXTAUTH_URL="https://your-railway-domain.up.railway.app"

# Google OAuth (for NextAuth + Gmail API)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# AI ENGINE
# ============================================
ANTHROPIC_API_KEY=""

# ============================================
# EMAIL — Instantly.ai (cold outreach)
# ============================================
INSTANTLY_API_KEY=""
INSTANTLY_BASE_URL="https://api.instantly.ai/api/v2"

# ============================================
# EMAIL — Gmail API (warm/branded outreach)
# ============================================
BRANDED_AGENCY_DOMAIN=""
BRANDED_FROM_NAME=""
BRANDED_FROM_EMAIL=""

# Gmail Push Notifications (Google Cloud Pub/Sub)
GMAIL_PUBSUB_TOPIC=""

# ============================================
# LINKEDIN — Meet Alfred
# ============================================
MEET_ALFRED_API_KEY=""
MEET_ALFRED_BASE_URL="https://app.meetalfred.com/api"

# ============================================
# PROSPECTING — Apollo.io
# ============================================
APOLLO_API_KEY=""

# ============================================
# BILLING — Stripe
# ============================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================
# DOCUMENTS — PandaDocs
# ============================================
PANDADOCS_API_KEY=""
PANDADOCS_PROPOSAL_TEMPLATE_ID=""
PANDADOCS_CONTRACT_TEMPLATE_ID=""

# ============================================
# MEETINGS — tl;dv
# ============================================
TLDV_API_KEY=""

# ============================================
# VOICE AI — Vapi.ai
# ============================================
VAPI_API_KEY=""

# ============================================
# EMAIL SIGNATURE (auto-appended to all outbound emails)
# ============================================
EMAIL_SIGNATURE_NAME=""
EMAIL_SIGNATURE_TITLE=""
EMAIL_SIGNATURE_COMPANY=""
EMAIL_SIGNATURE_PHONE=""
EMAIL_SIGNATURE_EMAIL=""
EMAIL_SIGNATURE_WEBSITE=""
EMAIL_SIGNATURE_BOOKING_URL=""
EMAIL_SIGNATURE_LINKEDIN=""
EMAIL_SIGNATURE_TWITTER=""
EMAIL_SIGNATURE_LOGO_URL=""

# ============================================
# WEBSITE INTEGRATION
# ============================================
# Site API keys are generated via POST /api/settings/site-api-keys
# No env var needed — keys are stored in the database

# ============================================
# RUNTIME
# ============================================
NODE_ENV="production"
