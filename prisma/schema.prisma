// ============================================
// SELF-OPTIMIZATION ENGINE
// ============================================

// Living ICP profile — rewrites itself from close data
model ICPProfile {
  id              String   @id @default(cuid())
  version         Int      @default(1)
  isActive        Boolean  @default(true)

  // Weighted criteria (JSON: { criterion: string, weight: number, evidence: string }[])
  industries      String?  // JSON: ranked industries with weights
  companySizes    String?  // JSON: size ranges with weights
  jobTitles       String?  // JSON: titles with weights
  geographies     String?  // JSON: regions with weights
  techStack       String?  // JSON: technologies correlated with close
  revenueRanges   String?  // JSON: revenue brackets with weights
  growthSignals   String?  // JSON: which Apollo signals predict close
  seniorityLevels String?  // JSON: Apollo seniority levels with weights

  // Anti-targets (negative weights from churn + lost deals)
  excludeIndustries String? // JSON: industries to avoid
  excludeSignals    String? // JSON: signals correlated with churn
  churnFingerprint  String? // JSON: profile patterns that predict churn
  expansionFingerprint String? // JSON: patterns that predict expansion

  // Performance metrics
  totalDealsAnalyzed Int    @default(0)
  winRate           Float?
  avgDealSize       Float?
  avgTimeToClose    Int?    // days
  topConvertingProfile String?

  // Apollo search parameters auto-generated from this profile
  apolloSearchParams String? // JSON: ready-to-use Apollo API params

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Sequence performance tracking — per-step analytics
model SequencePerformance {
  id             String   @id @default(cuid())
  sequenceId     String
  stepNumber     Int
  channel        String   // email, linkedin

  // Metrics
  sent           Int      @default(0)
  opened         Int      @default(0)
  clicked        Int      @default(0)
  replied        Int      @default(0)
  positiveReplied Int     @default(0)
  negativeReplied Int     @default(0)
  unsubscribed   Int      @default(0)
  bounced        Int      @default(0)
  meetingsBooked Int      @default(0)

  // Rates (pre-calculated for query efficiency)
  openRate       Float?
  replyRate      Float?
  positiveReplyRate Float?

  // Content tracking
  subjectLine    String?
  messageAngle   String?  // AI-classified angle of the message

  // Segment performance (JSON: { segment: string, replyRate: number }[])
  segmentPerformance String?

  // Time performance (JSON: { dayOfWeek: number, hour: number, replyRate: number }[])
  sendTimePerformance String?

  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())

  @@unique([sequenceId, stepNumber, periodStart])
}

// Objection library — accumulated from conversations, grouped by ICP segment
model ObjectionEntry {
  id             String   @id @default(cuid())
  type           String   // timing, budget, authority, need, competition
  severity       String   // soft, hard
  verbatim       String   // exact prospect words
  icpSegment     String?  // which ICP segment this came from
  contactId      String?
  dealId         String?
  dealOutcome    String?  // won, lost, stalled (updated post-close)

  // Counter-strategy (learned from deals that overcame this objection)
  counterStrategy String?
  counterWorked   Boolean?

  createdAt      DateTime @default(now())
}

// StageGate accuracy — immutable per-gate per-week record, never updated
model StageGateAccuracy {
  id              String   @id @default(cuid())
  stageGateId     String
  objectType      String
  fromStage       String
  toStage         String
  weekNumber      Int      // ISO week number
  year            Int

  // Immutable once written — append new weeks, never update historical
  totalTransitions Int     @default(0)
  truePositives    Int     @default(0)
  falsePositives   Int     @default(0)
  inconclusive     Int     @default(0)
  accuracy         Float?  // truePositives / (truePositives + falsePositives)
  confidenceThresholdAtTime Float? // what the threshold was when these decisions were made

  createdAt       DateTime @default(now())

  @@unique([stageGateId, weekNumber, year])
}

// Raw event log — replayable stream of every external API event
// Written BEFORE processing. If processing logic has a bug, replay raw events.
model RawEventLog {
  id          String   @id @default(cuid())
  source      String   // instantly, alfred, gmail, apollo, vapi
  eventType   String   // reply, open, click, bounce, connection_accepted, etc.
  rawPayload  String   // full JSON payload as received
  processed   Boolean  @default(false)
  processedAt DateTime?
  processingError String?
  contactId   String?  // resolved after processing
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([processed])
  @@index([createdAt])
}

// System changelog — every autonomous change the system makes
model SystemChangelog {
  id          String   @id @default(cuid())
  category    String   // icp, scoring, sequence, stage_gate, bant, client_health, send_timing
  changeType  String   // weight_adjusted, threshold_changed, step_rewritten, icp_updated, fingerprint_updated
  description String   // human-readable: "Upweighted hiring spike signal by 8 points"
  previousValue String? // JSON: what it was before
  newValue     String?  // JSON: what it is now
  dataEvidence String?  // JSON: the data that drove this change
  expectedImpact String? // AI's prediction of impact
  weekNumber   Int?     // ISO week number for grouping
  createdAt    DateTime @default(now())
}

