  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  drafts ContentDraft[]

  @@index([weekStarting])
  @@index([channel])
  @@index([status])
}

model ContentDraft {
  id           String   @id @default(cuid())
  calendarId   String?
  channel      String   // newsletter, blog, linkedin, twitter
  title        String?
  body         String   // The generated content
  voiceScore   Float?   // 0-1 how well it matches the VoiceProfile
  status       String   @default("draft") // draft, review, approved, scheduled, published, rejected
  publishAt    DateTime?
  publishedAt  DateTime?
  publishedUrl String?  // URL where it was published (blog post URL, LinkedIn post URL)
  metadata     String?  // JSON: channel-specific metadata (newsletter subject line, blog slug, etc.)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  calendar    ContentCalendar? @relation(fields: [calendarId], references: [id])
  performance ContentPerformance?
  usages      InsightUsage[]

  @@index([calendarId])
  @@index([channel])
  @@index([status])
  @@index([publishAt])
  @@index([createdAt])
}

model ContentPerformance {
  id                      String   @id @default(cuid())
  draftId                 String   @unique
  channel                 String
  opens                   Int      @default(0) // Newsletter opens
  clicks                  Int      @default(0) // Link clicks
  replies                 Int      @default(0) // Direct replies (newsletter/linkedin)
  views                   Int      @default(0) // Blog page views
  shares                  Int      @default(0) // Social shares
  comments                Int      @default(0) // LinkedIn/blog comments
  engagementRate          Float?   // Composite engagement metric
  pipelineEntriesGenerated Int     @default(0) // Leads generated from this content
  revenueInfluenced       Float?   // Deal value influenced by this content
  icpMatchRate            Float?   // % of engagers who match ICP
  measuredAt              DateTime @default(now())
  updatedAt               DateTime @updatedAt

  draft ContentDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([channel])
  @@index([measuredAt])
}

model NewsletterSubscriber {
  id              String   @id @default(cuid())
  email           String   @unique
  contactId       String?  // Link to CRM contact if identified
  subscribedAt    DateTime @default(now())
  unsubscribedAt  DateTime?
  isActive        Boolean  @default(true)
  openRate        Float?   // Running average
  clickRate       Float?   // Running average
  lastEngagement  DateTime?
  totalOpens      Int      @default(0)
  totalClicks     Int      @default(0)
  leadScoreImpact Int      @default(0) // Points added to contact's score from newsletter engagement
  tags            String?  // JSON array of interest tags based on click behavior
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contactId])
  @@index([isActive])
}
