generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           String    @default("member") // admin, manager, member
  teamId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  team         Team?          @relation(fields: [teamId], references: [id])
  accounts     Account[]
  sessions     Session[]
  ownedDeals   Deal[]         @relation("DealOwner")
  ownedContacts Contact[]     @relation("ContactOwner")
  activities   Activity[]
  tasks        Task[]
  auditLogs    AuditLog[]
  messages     Message[]
  comments     Comment[]
  notifications Notification[]
  assignedTickets Ticket[]       @relation("TicketAssignee")
  assignedConversations Conversation[] @relation("ConversationAssignee")
  organizedMeetings Meeting[] @relation("MeetingOrganizer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  permissions Permission[]
}

model Permission {
  id       String  @id @default(cuid())
  teamId   String
  resource String  // contacts, deals, tickets, etc.
  action   String  // create, read, update, delete
  allowed  Boolean @default(true)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, resource, action])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // created, updated, deleted, viewed
  resource   String   // contact, deal, ticket, etc.
  resourceId String
  details    String?  // JSON string of changes
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

// ============================================
// CRM CORE
// ============================================

model Contact {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String?  @unique
  phone          String?
  jobTitle       String?

  // Full 8-stage lifecycle (data layer): subscriber, lead, mql, sql, opportunity, customer, evangelist
  // Simplified 5-stage UI view: lead, engaged (=mql), opportunity (=sql+opportunity), client (=customer), advocate (=evangelist)
  lifecycleStage String   @default("subscriber")
  leadStatus     String?  // new, contacted, interested, unqualified, bad_timing, recycled, nurturing, re_engaged

  // Dual scoring model: fitScore persists forever, engagementScore decays
  leadScore      Int      @default(0)   // composite (fitScore + engagementScore)
  fitScore       Int      @default(0)   // demographic + firmographic (never decays)
  engagementScore Int     @default(0)   // behavioral + recency (decays 25%/month, resets at 90 days)
  engagementScoreLastDecay DateTime?    // when decay was last applied

  // Stage tracking
  stageEnteredAt DateTime?              // when current lifecycle stage was entered
  stageHistory   String?                // JSON: [{ from, to, triggeredBy, reason, timestamp }]

  // BANT qualification (auto-extracted from conversations by AI)
  bantBudget     String?  // "confirmed" | "unconfirmed" | "no_budget"
  bantAuthority  String?  // "decision_maker" | "influencer" | "no_authority"
  bantNeed       String?  // "confirmed" | "exploring" | "no_need"
  bantTimeline   String?  // "immediate" | "1_3_months" | "3_6_months" | "6_plus_months" | "no_timeline"
  bantNotes      String?  // JSON: { budget: "exact words", authority: "exact words", need: "exact words", timeline: "exact words" }
  bantScore      Int      @default(0)   // 0-4 count of confirmed BANT criteria
  bantLastUpdated DateTime?
  bantGapSummary  String?  // comma-separated missing BANT fields, e.g. "budget, timeline"

  ownerId        String?
  companyId      String?
  source         String?  // instantly, inbound, referral, organic, paid
  domainTier     String   @default("cold") // cold = Instantly pre-warmed, warm = branded agency domain
  handoffInProgress Boolean @default(false) // true during cold→warm domain handoff to prevent tick loop race
  globalOptOut    Boolean  @default(false) // CAN-SPAM/GDPR: when true, NO outreach on ANY channel
  optOutAt        DateTime? // when they opted out
  customFields   String?  // JSON

  // Scoring optimization
  scoreDirty         Boolean   @default(true)  // set true when any signal changes, cleared after scoring
  lastScoreEvaluated DateTime? // when lead score was last calculated

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner      User?      @relation("ContactOwner", fields: [ownerId], references: [id])
  company    Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals      Deal[]
  activities Activity[]
  tickets    Ticket[]
  tasks      Task[]
  messages   Message[]
  formSubmissions FormSubmission[]
  listMemberships ListMembership[]
  emailEvents EmailEvent[]
  sequenceEnrollments SequenceEnrollment[]
  leads      Lead[]
  clientLifecycles ClientLifecycle[]
  pageViews  PageView[]
  pandaDocuments PandaDocument[]
  aiConversationLogs AIConversationLog[]
  conversations Conversation[]
  meetings   Meeting[]
  feedbackSurveys FeedbackSurvey[]

  @@index([companyId])
  @@index([ownerId])
  @@index([lifecycleStage])
  @@index([scoreDirty])
  @@index([leadScore])
  @@index([createdAt])
  @@index([source])
}

model Company {
  id           String   @id @default(cuid())
  name         String
  domain       String?  @unique
  industry     String?
  size         String?  // 1-10, 11-50, 51-200, 201-500, 501-1000, 1001+
  revenue      Float?
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String?
  description  String?

  // Company lifecycle mirrors contact stages, pushed forward by highest contact stage
  lifecycleStage String  @default("subscriber")

  customFields String?  // JSON
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contacts Contact[]
  deals    Deal[]
  tickets  Ticket[]
  leads    Lead[]
  clientLifecycles ClientLifecycle[]

  @@index([lifecycleStage])
}

// Lead: bridge object between Contact and Deal (HubSpot 2024 pattern)
// A Lead cannot exist standalone — must attach to a Contact or Company
// Has its own pipeline: new → attempting → connected → qualified → disqualified
model Lead {
  id          String   @id @default(cuid())
  contactId   String
  companyId   String?

  // Lead pipeline stage (separate from contact lifecycle)
  stage       String   @default("new") // new, attempting, connected, qualified, disqualified
  stageEnteredAt DateTime @default(now())

  // BANT qualification status at lead level
  bantBudget    Boolean  @default(false)
  bantAuthority Boolean  @default(false)
  bantNeed      Boolean  @default(false)
  bantTimeline  Boolean  @default(false)
  bantNotes     String?  // JSON: detailed qualification notes

  // Source and channel tracking
  source        String?  // form_fill, linkedin, referral, instantly, apollo, inbound
  channel       String?  // email, linkedin, phone, chat, form
  campaignId    String?  // which campaign generated this lead

  // Auto-advance rules
  // "attempting" = outreach activity logged
  // "connected" = reply received
  // "qualified" = BANT 4/4 or 3/4 with strong signals → forces deal creation
  // "disqualified" = hard no, bad fit, or 4+ failed attempts

  disqualifyReason String? // bad_fit, no_budget, competitor, timing, unresponsive
  qualifiedAt      DateTime?
  disqualifiedAt   DateTime?

  dealId        String?  // deal created when lead qualifies

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  company  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([companyId])
  @@index([stage])
  @@index([dealId])
  @@index([createdAt])
}

model Deal {
  id          String   @id @default(cuid())
  name        String
  amount      Float?
  currency    String   @default("USD")

  // Agency-specific pipeline stages with enforced win probability
  // discovery (10%) → proposal_sent (40%) → negotiation (60%) → contract_sent (80%) → closed_won (100%) → closed_lost (0%)
  stage       String   @default("discovery")
  pipeline    String   @default("new_business") // new_business, client_lifecycle

  // Win probability auto-set by stage but overridable by AI
  probability Int?
  closeDate   DateTime?

  // Stage gate tracking
  stageEnteredAt DateTime?
  stageHistory   String?  // JSON: [{ from, to, triggeredBy, reason, timestamp, requiredFieldsSnapshot }]

  // Required fields per stage (enforced by lifecycle engine)
  painPoints     String?  // required at discovery
  scopeOfWork    String?  // required at proposal_sent
  proposalDoc    String?  // required at proposal_sent
  pricingBreakdown String? // required at proposal_sent
  negotiationNotes String? // required at negotiation
  revisedTerms   String?  // required at negotiation
  contractSentAt DateTime? // required at contract_sent
  contractVersion String?  // required at contract_sent
  contractSignedAt DateTime? // set at closed_won
  actualAmount   Float?   // set at closed_won (may differ from estimated)
  paymentTerms   String?  // set at closed_won
  startDate      DateTime? // set at closed_won (implementation/project start)
  contractLength Int?     // months, set at closed_won

  // Loss tracking (required for closed_lost — no skipping)
  lostReason     String?  // budget, authority, need, timing, competitor, went_silent, scope_mismatch
  lostToCompetitor String? // competitor name if applicable
  lostNotes      String?

  // BANT snapshot at deal creation
  bantSnapshot   String?  // JSON: BANT status when deal was created

  ownerId     String?
  contactId   String?
  companyId   String?
  customFields String? // JSON
  position    Int      @default(0) // for kanban ordering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User?      @relation("DealOwner", fields: [ownerId], references: [id])
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company    Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities Activity[]
  quotes     Quote[]
  aiConversationLogs AIConversationLog[]
  feedbackSurveys FeedbackSurvey[]

  @@index([contactId])
  @@index([companyId])
  @@index([ownerId])
  @@index([stage])
  @@index([pipeline])
  @@index([closeDate])
  @@index([createdAt])
}

// Client Lifecycle Pipeline — the post-sale revenue engine
// This is where 80% of agency revenue lives (retainers, renewals, expansion, upsells)
model ClientLifecycle {
  id          String   @id @default(cuid())
  contactId   String
  companyId   String?
  dealId      String?  // the deal that created this client relationship

  // Post-sale stages: onboarding → active → renewal → expansion → at_risk → churned → win_back
  stage       String   @default("onboarding")
  stageEnteredAt DateTime @default(now())
  stageHistory   String?  // JSON: [{ from, to, triggeredBy, reason, timestamp }]

  // Health tracking
  healthScore Int      @default(80) // 0-100, starts high, degrades on negative signals
  npsScore    Int?
  csatScore   Int?
  lastHealthCheck DateTime?

  // Contract tracking
  contractValue  Float?
  monthlyValue   Float?
  renewalDate    DateTime?
  contractStartDate DateTime?
  contractEndDate   DateTime?

  // Engagement metrics
  ticketCount    Int      @default(0)
  avgTicketSentiment String? // positive, neutral, negative
  lastActivityAt DateTime?
  scopeCreepCount Int     @default(0) // requests outside scope

  // Expansion tracking
  expansionOpportunity String? // JSON: { type, estimatedValue, description }
  upsellSignals  String?  // JSON: [{ signal, date, description }]

  // Churn signals
  churnRiskLevel String   @default("low") // low, medium, high, critical
  churnSignals   String?  // JSON: [{ signal, date, severity }]

  // Win-back (if churned)
  churnedAt      DateTime?
  churnReason    String?
  winBackAttempts Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  company  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  feedbackSurveys FeedbackSurvey[]

  @@index([contactId])
  @@index([companyId])
  @@index([stage])
  @@index([churnRiskLevel])
  @@index([renewalDate])
}

// Stage Gate Configuration — defines required fields and conditions for each stage transition
model StageGate {
  id          String   @id @default(cuid())
  objectType  String   // contact, deal, lead, client_lifecycle
  fromStage   String
  toStage     String
  requiredFields String // JSON: ["field1", "field2"] — fields that must be populated
  conditions  String?  // JSON: [{ field, operator, value }] — additional conditions
  autoAdvance Boolean  @default(false) // can AI auto-advance without human review?
  confidenceThreshold Float? // minimum AI confidence to auto-advance (0-1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([objectType, fromStage, toStage])
}

// Lifecycle Transition Audit Trail — every stage change is recorded, forward-only enforced
model LifecycleTransition {
  id          String   @id @default(cuid())
  objectType  String   // contact, deal, lead, client_lifecycle
  objectId    String
  fromStage   String
  toStage     String
  triggeredBy String   // ai_auto, workflow, manual, deal_sync, ticket_signal
  reason      String?  // why this transition happened
  gateValidation String? // JSON: { passed: true/false, requiredFields: {}, missingFields: [] }
  confidence  Float?   // AI confidence in this decision (0-1)
  metadata    String?  // JSON: additional context
  createdAt   DateTime @default(now())

  @@index([objectType, objectId])
  @@index([createdAt])
}

model Activity {
  id         String   @id @default(cuid())
  type       String   // email, call, meeting, note, task
  subject    String?
  body       String?
  userId     String
  contactId  String?
  dealId     String?
  duration   Int?     // in seconds
  outcome    String?  // connected, no_answer, left_voicemail, busy
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([dealId])
  @@index([userId])
  @@index([createdAt])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("todo") // todo, call, email, follow_up
  priority    String    @default("medium") // low, medium, high, urgent
  status      String    @default("pending") // pending, in_progress, completed
  dueDate     DateTime?
  userId      String?
  contactId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contactId])
  @@index([status])
  @@index([dueDate])
}

// ============================================
// SERVICE & TICKETING
// ============================================

model Ticket {
  id          String   @id @default(cuid())
  subject     String
  description String?
  status      String   @default("new") // new, waiting_on_contact, waiting_on_us, in_progress, review_qa, closed
  priority    String   @default("medium") // low, medium, high, urgent
  category    String?
  pipeline    String   @default("support")
  contactId   String?
  companyId   String?
  assigneeId  String?
  slaDeadline DateTime?
  resolvedAt  DateTime?

  // Revenue signal fields (fed into ticket intelligence engine)
  sentiment   String?  // positive, neutral, negative (AI-analyzed)
  scopeCreep  Boolean  @default(false) // request outside current scope → upsell signal
  churnSignal Boolean  @default(false) // negative pattern detected
  upsellSignal Boolean @default(false) // capability request outside current scope

  customFields String? // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignee User?     @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments Comment[]

  @@index([contactId])
  @@index([companyId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  ticketId  String
  userId    String
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  body        String
  category    String?
  status      String   @default("draft") // draft, published
  viewCount   Int      @default(0)
  helpfulCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeedbackSurvey {
  id        String   @id @default(cuid())
  type      String   // nps, csat, ces
  score     Int
  comment   String?
  contactId String?
  dealId    String?
  clientLifecycleId String? // link to client lifecycle for post-sale surveys
  createdAt DateTime @default(now())

  contact          Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal             Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  clientLifecycle  ClientLifecycle?  @relation(fields: [clientLifecycleId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([dealId])
}

// ============================================
// MARKETING & AUTOMATION
// ============================================

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String   // HTML
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailEvent {
  id         String   @id @default(cuid())
  contactId  String
  templateId String?
  type       String   // sent, opened, clicked, bounced, unsubscribed
  metadata   String?  // JSON
  createdAt  DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([type])
  @@index([createdAt])
}

model Form {
  id          String   @id @default(cuid())
  name        String
  fields      String   // JSON array of field definitions
  submitLabel String   @default("Submit")
  redirectUrl String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions FormSubmission[]
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  contactId String?
  data      String   // JSON
  createdAt DateTime @default(now())

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([formId])
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  trigger     String   // JSON: { type, conditions }
  actions     String   // JSON array of action steps
  isActive    Boolean  @default(false)
  lastRunAt   DateTime?
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  type        String   // email, social, ads, content
  status      String   @default("draft") // draft, active, paused, completed
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  metrics     String?  // JSON: { sent, opened, clicked, converted }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactList {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("static") // static, dynamic
  filters   String?  // JSON for dynamic lists
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships ListMembership[]
}

model ListMembership {
  id        String   @id @default(cuid())
  listId    String
  contactId String
  createdAt DateTime @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
}

// ============================================
// SALES TOOLS
// ============================================

model Sequence {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("outreach") // outreach, bant_qualification, nurture, re_engagement
  steps       String   // JSON array of sequence steps
  isActive    Boolean  @default(true)
  aiGenerated Boolean  @default(false) // AI wrote the sequence copy
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments SequenceEnrollment[]
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?  // url or physical
  type        String   @default("one_on_one") // one_on_one, group, round_robin, consultation
  contactId   String?
  organizerId String?
  status      String   @default("scheduled") // scheduled, requested, completed, cancelled, no_show
  reminderSentAt DateTime? // tracks when pre-meeting reminder was sent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  organizer   User?    @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  transcript  MeetingTranscript?

  @@index([contactId])
  @@index([organizerId])
}

model MeetingTranscript {
  id          String   @id @default(cuid())
  meetingId   String   @unique
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  source      String   @default("tldv") // tldv, manual, vapi
  rawTranscript String // full transcript text
  summary     String?  // AI-generated summary
  actionItems String?  // JSON array of action items
  bantExtract String?  // JSON: { budget, authority, need, timeline, confidence }
  dealSignals String?  // JSON: { buyIntent, objections, nextSteps, stageRecommendation }
  sentiment   String?  // positive, neutral, negative, mixed
  followUpSent Boolean @default(false)
  analyzedAt  DateTime?
  createdAt   DateTime @default(now())
}

model Quote {
  id          String   @id @default(cuid())
  name        String
  dealId      String
  lineItems   String   // JSON array
  subtotal    Float
  tax         Float    @default(0)
  discount    Float    @default(0)
  total       Float
  status      String   @default("draft") // draft, sent, signed, declined
  expiresAt   DateTime?
  signedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

// ============================================
// COMMUNICATION
// ============================================

model Conversation {
  id        String   @id @default(cuid())
  channel   String   // email, chat, whatsapp
  status    String   @default("open") // open, assigned, closed
  assigneeId String?
  contactId String?
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignee User?    @relation("ConversationAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([assigneeId])
  @@index([contactId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  userId         String?
  contactId      String?
  body           String
  direction      String   @default("inbound") // inbound, outbound
  isInternal     Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([conversationId])
}

model Notification {
